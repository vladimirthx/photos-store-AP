generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id              String   @id @default(uuid())
  title           String
  description     String?
  price           Float
  originalKey     String
  watermarkedUrl  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
